---
// Email capture via self-hosted Listmonk (same instance as Dreamkit).
// List: "Deckyard launch updates" (id 13, double opt-in) on listmonk.dreamkit.eu.
import { ui, defaultLang, type Lang } from '../i18n/ui';

const LISTMONK_URL = 'https://listmonk.dreamkit.eu/subscription/form';
const LIST_UUID = '7c6489d5-d6a8-40c0-be60-bd0918cbdc06';

interface Props {
  id: string;
  lang?: Lang;
  buttonLabel?: string;
}
const { id, lang = defaultLang, buttonLabel } = Astro.props;
const t = ui[lang].waitlist;
const label = buttonLabel ?? t.button;
---

<div class="waitlist" data-waitlist>
  <form
    class="waitlist-form"
    method="post"
    action={LISTMONK_URL}
    data-waitlist-form
    data-status-ok={t.statusOk}
    data-status-error={t.statusError}
  >
    <input type="hidden" name="l" value={LIST_UUID} />
    <label class="wl-nonce" aria-hidden="true">
      {t.honeypot}
      <input type="text" name="nonce" tabindex="-1" autocomplete="off" />
    </label>
    <label class="wl-nonce" for={`${id}-email`}>{t.emailLabel}</label>
    <input
      id={`${id}-email`}
      type="email"
      name="email"
      required
      placeholder={t.placeholder}
      autocomplete="email"
    />
    <button class="btn btn-primary" type="submit">{label}</button>
  </form>
  <p class="waitlist-status" data-waitlist-status hidden aria-live="polite"></p>
  <p class="waitlist-note">{t.note}</p>
</div>

<script>
  function initWaitlist() {
    document.querySelectorAll<HTMLFormElement>('[data-waitlist-form]').forEach((form) => {
      if (form.dataset.bound) return;
      form.dataset.bound = 'true';
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const status = form.parentElement?.querySelector<HTMLElement>('[data-waitlist-status]');
        const button = form.querySelector<HTMLButtonElement>('button[type=submit]');
        if (button) button.disabled = true;
        try {
          // Listmonk sends no CORS headers; no-cors means an opaque response,
          // so success is optimistic — the double-opt-in email is the real confirmation.
          await fetch(form.action, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>),
          });
          if (status) {
            status.hidden = false;
            status.dataset.state = 'ok';
            status.textContent =
              form.dataset.statusOk ?? 'Almost there: check your inbox to confirm your address.';
          }
          form.reset();
        } catch {
          if (status) {
            status.hidden = false;
            status.dataset.state = 'error';
            status.textContent =
              form.dataset.statusError ?? 'That did not work. Please try again in a moment.';
          }
        } finally {
          if (button) button.disabled = false;
        }
      });
    });
  }
  initWaitlist();
  document.addEventListener('astro:page-load', initWaitlist);
</script>
