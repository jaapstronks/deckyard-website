---
// Signature hero element: the same slide layout, restyled by three fictional
// organization themes — the "always on brand" promise in one glance.
---

<div
  class="cycler"
  role="img"
  aria-label="The same slide layout shown in three different organization brand identities: a museum, a municipality and a nonprofit."
>
  <div class="cycler-stage">
    <div class="cycler-slide cycler-slide--museum" aria-hidden="true">
      <p class="cycler-brand">Museum Nachtlicht</p>
      <p class="cycler-title">Annual report:<br /><em>2026</em> in numbers</p>
      <div class="cycler-bars"><span></span><span></span><span></span><span></span><span></span></div>
      <div class="cycler-foot"><span>Visitors per quarter</span><span>08 / 14</span></div>
    </div>

    <div class="cycler-slide cycler-slide--city" aria-hidden="true">
      <p class="cycler-brand">City of Waterland</p>
      <p class="cycler-title">Neighborhood <em>budget</em>:<br />where it went</p>
      <div class="cycler-bars"><span></span><span></span><span></span><span></span><span></span></div>
      <div class="cycler-foot"><span>Spending per district</span><span>08 / 14</span></div>
    </div>

    <div class="cycler-slide cycler-slide--ngo" aria-hidden="true">
      <p class="cycler-brand">Stichting Helder</p>
      <p class="cycler-title">Impact review<br />for our <em>donors</em></p>
      <div class="cycler-bars"><span></span><span></span><span></span><span></span><span></span></div>
      <div class="cycler-foot"><span>Programs reached</span><span>08 / 14</span></div>
    </div>
  </div>
  <div class="cycler-dots" aria-hidden="true"><span></span><span></span><span></span></div>
  <p class="cycler-caption">One slide layout, three organizations. Never off brand.</p>
</div>
