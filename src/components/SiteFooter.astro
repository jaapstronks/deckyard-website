---
import DeckyardMark from './DeckyardMark.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div>
        <p class="footer-brand"><DeckyardMark size={26} /> Deckyard</p>
        <p class="footer-tag">
          An open source presentation platform for organizations that want to own their story:
          their brand, their data, their infrastructure.
        </p>
      </div>

      <div class="footer-links">
        <div>
          <h4>Follow along</h4>
          <ul>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/rss.xml">RSS feed</a></li>
          </ul>
        </div>
        <div>
          <h4>Product</h4>
          <ul>
            <li><a href="/docs/creating/">Documentation</a></li>
            <li><a href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noreferrer">GitHub</a></li>
            <li><a href="https://dreamkit.eu" target="_blank" rel="noreferrer">Dreamkit</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-meta">
      <span>© {year} Deckyard · Bureau Bolster</span>
      <span>Made in the Netherlands · Hosted in Europe · MIT licensed</span>
    </div>
  </div>
</footer>
