---
import DeckyardMark from './DeckyardMark.astro';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
const isBlog = currentPath.startsWith('/blog');
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Deckyard home">
      <DeckyardMark size={30} />
      <span class="brand-name">Deckyard</span>
      <span class="brand-badge">Beta</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/blog/" aria-current={isBlog ? 'page' : undefined}>Blog</a>
      <a href="/docs/creating/">Docs</a>
      <a href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noopener">GitHub</a>
    </nav>
  </div>
</header>
