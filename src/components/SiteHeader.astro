---
import LanguagePicker from './LanguagePicker.astro';
import { useTranslations, type Locale, defaultLocale } from '../i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<header class="site-header" data-js="siteHeader">
  <div class="container header-inner">
    <a class="brand" href={getLocalePath('/')} aria-label={`${t('site.name')} ${t('nav.home')}`}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="34" height="31" viewBox="0 0 217 198" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(0,198) scale(0.1,-0.1)" fill="currentColor" stroke="none">
            <path d="M963 1939 c-45 -23 -94 -52 -109 -64 -32 -25 -35 -69 -8 -90 11 -8 159 -90 329 -184 518 -285 587 -325 602 -347 12 -20 12 -24 -9 -47 -22 -24 -530 -312 -605 -343 -24 -11 -57 -15 -93 -12 -48 4 -84 20 -290 134 -129 72 -272 151 -318 175 -86 46 -110 76 -81 104 20 20 226 125 245 125 20 0 278 -136 294 -155 16 -19 7 -31 -41 -56 -33 -17 -40 -24 -37 -46 2 -21 20 -35 88 -74 104 -60 139 -70 185 -58 31 9 303 157 332 181 17 13 17 89 1 110 -7 9 -125 78 -263 153 -137 76 -308 169 -380 209 -192 105 -174 108 -500 -75 -230 -129 -263 -150 -283 -185 -22 -39 -22 -41 -20 -415 l3 -376 26 -34 c15 -19 60 -52 100 -75 288 -160 823 -452 867 -472 80 -36 126 -29 259 44 765 421 863 477 882 508 43 69 39 215 -6 260 -14 15 -37 26 -51 26 -29 0 -172 -76 -617 -329 l-310 -176 -70 0 -70 0 -225 126 c-124 70 -276 155 -338 189 -116 65 -142 88 -142 127 0 33 36 66 63 57 20 -6 315 -166 537 -290 100 -56 108 -59 175 -59 l70 0 230 131 c127 72 344 193 484 270 193 105 258 145 272 169 16 25 19 51 19 158 0 143 -8 170 -62 210 -18 13 -242 138 -497 277 -372 203 -473 254 -510 258 -39 3 -58 -2 -128 -39z"/>
          </g>
        </svg>
      </span>
      <span class="brand-name">{t('site.name')}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <div class="nav-quick">
        <a class="nav-link-inline" href={getLocalePath('/features')}>{t('nav.features')}</a>
        <a class="nav-link-inline" href={getLocalePath('/features/ai')}>{t('nav.developers')}</a>
        <a class="nav-link-inline" href={getLocalePath('/pricing')}>{t('nav.pricing')}</a>
        <a class="nav-link-inline" href="/docs/">{t('nav.docs')}</a>
        <a class="nav-link-inline" href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noreferrer">{t('nav.github')}</a>
        <a class="btn btn-primary" href="https://sandbox.deckyard.eu">
          {t('nav.trySandbox')}
        </a>
      </div>

      <button
        class="nav-toggle"
        type="button"
        data-js="navToggle"
        aria-expanded="false"
        aria-controls="siteMenu"
      >
        <span class="sr-only">{t('nav.menu')}</span>
        <span aria-hidden="true" class="nav-toggle-bars"></span>
      </button>

      <div class="nav-drawer" id="siteMenu" data-js="navLinks" aria-label={t('nav.menu')}>
        <div class="nav-drawer-top">
          <div class="nav-drawer-title">{t('nav.menu')}</div>
          <button class="btn btn-ghost btn-icon" type="button" data-js="navClose" aria-label={t('nav.closeMenu')}>
            ✕
          </button>
        </div>

        <div class="nav-drawer-section">
          <div class="nav-drawer-label">{t('footer.product')}</div>
          <a class="nav-link" href={getLocalePath('/features')}>{t('footer.features')}</a>
          <a class="nav-link" href={getLocalePath('/features/slide-types')}>{t('footer.slideTypes')}</a>
          <a class="nav-link" href={getLocalePath('/features/ai')}>{t('footer.aiGeneration')}</a>
          <a class="nav-link" href={getLocalePath('/features/interactions')}>{t('footer.interactions')}</a>
          <a class="nav-link" href={getLocalePath('/features/ai')}>{t('footer.api')}</a>
          <a class="nav-link" href={getLocalePath('/pricing')}>{t('footer.pricing')}</a>
        </div>

        <div class="nav-drawer-section">
          <div class="nav-drawer-label">{t('footer.resources')}</div>
          <a class="nav-link" href="/docs/">{t('footer.documentation')}</a>
          <a class="nav-link" href={getLocalePath('/self-hosting')}>{t('footer.selfHosting')}</a>
          <a class="nav-link" href={getLocalePath('/eu-privacy')}>{t('footer.euPrivacy')}</a>
          <a class="nav-link" href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noreferrer">
            {t('footer.github')}
          </a>
        </div>

        <div class="nav-drawer-section">
          <LanguagePicker locale={locale} currentPath={currentPath} variant="mobile" />
        </div>

        <div class="nav-drawer-section">
          <a class="btn btn-primary" href="https://sandbox.deckyard.eu">
            {t('nav.trySandbox')}
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>
