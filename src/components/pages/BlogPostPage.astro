---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import Waitlist from '../Waitlist.astro';
import { ui, localizePath, type Lang } from '../../i18n/ui';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
}
const { post, lang } = Astro.props;
const t = ui[lang].blogPost;
const { Content } = await render(post);
const { title, intro, pubDate, category, author, heroImage, heroImageAlt, description } = post.data;

const dateLabel = new Intl.DateTimeFormat(t.dateLocale, {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(pubDate);
const blogHref = localizePath('/blog/', lang);
---

<SiteLayout
  title={`${title} ${t.metaTitleSuffix}`}
  description={description ?? intro}
  ogImage={heroImage}
  type="article"
  publishedTime={pubDate.toISOString()}
>
  <div class="reading-progress" aria-hidden="true"></div>

  <article>
    <header class="article-hero">
      <div class="container">
        <div class="article-hero-inner">
          <p class="kicker kicker--center">{category}</p>
          <h1 transition:name={`post-title-${post.id}`}>{title}</h1>
          <p class="article-intro">{intro}</p>
          <p class="article-byline">
            <span>{author}</span>
            <time datetime={pubDate.toISOString()}>{dateLabel}</time>
          </p>
        </div>
      </div>

      {
        heroImage && (
          <figure class="article-figure">
            <img
              src={heroImage}
              alt={heroImageAlt ?? ''}
              transition:name={`post-hero-${post.id}`}
            />
          </figure>
        )
      }
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <p class="kicker">{t.followKicker}</p>
      <h2 style="font-size: 1.5rem;">{t.followTitle}</h2>
      <Waitlist id={`article-${post.id}`} lang={lang} />
      <p style="margin-top: 28px;"><a href={blogHref}>{t.allPosts}</a></p>
    </footer>
  </article>
</SiteLayout>
