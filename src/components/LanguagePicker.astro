---
import { locales, localeNames, getLocalizedPath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  currentPath: string;
  variant?: 'default' | 'mobile';
}

const { locale, currentPath, variant = 'default' } = Astro.props;

// Get localized paths for all languages
function getLocalizedUrl(targetLocale: Locale): string {
  return getLocalizedPath(currentPath, targetLocale);
}

const isMobile = variant === 'mobile';
---

<div class={`language-picker ${isMobile ? 'language-picker--mobile' : ''}`} data-language-picker>
  <button
    type="button"
    class="language-picker-trigger"
    aria-expanded="false"
    aria-haspopup="listbox"
    aria-label="Select language"
    data-language-trigger
  >
    <span class="language-picker-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
        <path d="M2 12h20"/>
      </svg>
    </span>
    <span class="language-picker-label">{localeNames[locale]}</span>
    <span class="language-picker-chevron" aria-hidden="true">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </span>
  </button>

  <ul
    class="language-picker-dropdown"
    role="listbox"
    aria-label="Available languages"
    data-language-dropdown
    hidden
  >
    {locales.map((loc) => (
      <li role="option" aria-selected={loc === locale ? 'true' : 'false'}>
        <a
          href={getLocalizedUrl(loc)}
          class={`language-picker-option ${loc === locale ? 'language-picker-option--active' : ''}`}
          lang={loc}
          hreflang={loc}
        >
          {localeNames[loc]}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  // Client-side language picker interactivity
  function initLanguagePickers() {
    const pickers = document.querySelectorAll('[data-language-picker]');

    pickers.forEach((picker) => {
      const trigger = picker.querySelector('[data-language-trigger]') as HTMLButtonElement;
      const dropdown = picker.querySelector('[data-language-dropdown]') as HTMLUListElement;

      if (!trigger || !dropdown) return;

      function open() {
        dropdown.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        picker.classList.add('is-open');
        // Focus first option
        const firstOption = dropdown.querySelector('a');
        firstOption?.focus();
      }

      function close() {
        dropdown.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        picker.classList.remove('is-open');
      }

      function toggle() {
        if (dropdown.hidden) {
          open();
        } else {
          close();
        }
      }

      // Toggle on click
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        toggle();
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!picker.contains(e.target as Node)) {
          close();
        }
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !dropdown.hidden) {
          close();
          trigger.focus();
        }
      });

      // Keyboard navigation within dropdown
      dropdown.addEventListener('keydown', (e) => {
        const options = Array.from(dropdown.querySelectorAll('a'));
        const currentIndex = options.findIndex((opt) => opt === document.activeElement);

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          const nextIndex = (currentIndex + 1) % options.length;
          options[nextIndex]?.focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          const prevIndex = (currentIndex - 1 + options.length) % options.length;
          options[prevIndex]?.focus();
        } else if (e.key === 'Home') {
          e.preventDefault();
          options[0]?.focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          options[options.length - 1]?.focus();
        }
      });
    });
  }

  // Initialize on page load
  initLanguagePickers();

  // Re-initialize after Astro navigation (for View Transitions)
  document.addEventListener('astro:after-swap', initLanguagePickers);
</script>

<style>
  .language-picker {
    position: relative;
    display: inline-flex;
  }

  .language-picker--mobile {
    width: 100%;
  }

  .language-picker-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    background: var(--white);
    cursor: pointer;
    font-weight: 600;
    font-size: 13px;
    color: var(--gray-700);
    transition: border-color 150ms ease, background 150ms ease;
  }

  .language-picker-trigger:hover {
    background: var(--gray-100);
    border-color: var(--gray-200);
  }

  .language-picker.is-open .language-picker-trigger {
    border-color: rgba(13, 78, 54, 0.30);
    background: var(--gray-100);
  }

  .language-picker--mobile .language-picker-trigger {
    width: 100%;
    justify-content: flex-start;
  }

  .language-picker-icon {
    display: inline-flex;
    color: var(--gray-500);
  }

  .language-picker-label {
    flex: 1;
    text-align: left;
  }

  .language-picker-chevron {
    display: inline-flex;
    color: var(--gray-400);
    transition: transform 150ms ease;
  }

  .language-picker.is-open .language-picker-chevron {
    transform: rotate(180deg);
  }

  .language-picker-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    z-index: 100;
    min-width: 160px;
    max-height: 320px;
    overflow-y: auto;
    padding: 6px;
    margin: 0;
    list-style: none;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(17, 24, 39, 0.12);
  }

  .language-picker--mobile .language-picker-dropdown {
    position: static;
    width: 100%;
    max-height: none;
    margin-top: 8px;
    box-shadow: none;
    border: 1px solid var(--gray-200);
  }

  .language-picker-dropdown li {
    margin: 0;
  }

  .language-picker-option {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 14px;
    color: var(--gray-700);
    text-decoration: none;
    transition: background 150ms ease;
  }

  .language-picker-option:hover {
    background: var(--gray-100);
    text-decoration: none;
  }

  .language-picker-option:focus {
    outline: none;
    background: var(--gray-100);
  }

  .language-picker-option--active {
    font-weight: 700;
    color: var(--brand-primary);
    background: rgba(13, 78, 54, 0.06);
  }

  .language-picker-option--active:hover {
    background: rgba(13, 78, 54, 0.10);
  }

  /* Hide on smaller screens in header (show mobile version in drawer) */
  @media (max-width: 980px) {
    .language-picker:not(.language-picker--mobile) {
      display: none;
    }
  }
</style>
