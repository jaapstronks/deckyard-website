---
import IconSprite from '../components/IconSprite.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getLocaleFromUrl, useTranslations, type Locale, locales, defaultLocale, getPathWithoutLocale } from '../i18n';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  ogImage = '/images/deckyard-editor-preview.png',
  type = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;
const locale = Astro.props.locale || getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

// Site configuration
const siteUrl = 'https://deckyard.eu';
const siteName = 'Deckyard';
const twitterHandle = '@deckyard';

// Build canonical URL (always points to the current locale version)
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

// Build OG image URL
const ogImageUrl = new URL(ogImage, siteUrl).href;

// Get path without locale for hreflang generation
const pathWithoutLocale = getPathWithoutLocale(Astro.url.pathname);

// JSON-LD structured data
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Deckyard',
  url: siteUrl,
  logo: `${siteUrl}/images/deckyard-logo.png`,
  description: 'Open source, self-hosted presentation platform with real-time audience interactions.',
  sameAs: [
    'https://github.com/jaapstronks/deckyard',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'technical support',
    url: 'https://github.com/jaapstronks/deckyard/discussions',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description: 'The presentation platform that respects your data. Open source, self-hosted, GDPR-compliant.',
  inLanguage: locales,
  publisher: {
    '@type': 'Organization',
    name: 'Deckyard',
  },
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: description,
  url: canonicalUrl,
  inLanguage: locale,
  isPartOf: {
    '@type': 'WebSite',
    name: siteName,
    url: siteUrl,
  },
  ...(publishedTime && { datePublished: publishedTime }),
  ...(modifiedTime && { dateModified: modifiedTime }),
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Deckyard',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
  },
  description: 'Open source presentation software with real-time polls, Q&A, and audience interactions.',
  featureList: [
    'Real-time audience polls',
    'Live Q&A sessions',
    'AI-powered slide generation',
    'Self-hosted deployment',
    'GDPR compliant',
    'Custom themes and branding',
  ],
};

// Generate breadcrumb schema from path
function generateBreadcrumbs() {
  const segments = pathWithoutLocale.split('/').filter(Boolean);
  if (segments.length === 0) return null;

  const breadcrumbNames: Record<string, string> = {
    'features': 'Features',
    'pricing': 'Pricing',
    'compare': 'Compare',
    'self-hosting': 'Self-Hosting',
    'eu-privacy': 'EU & Privacy',
    'slide-types': 'Slide Types',
    'ai': 'AI Generation',
    'interactions': 'Live Interactions',
    'mentimeter': 'vs Mentimeter',
    'slides-com': 'vs Slides.com',
    'google-slides': 'vs Google Slides',
    'powerpoint': 'vs PowerPoint',
  };

  const items = [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
  ];

  let currentPath = '';
  segments.forEach((segment, index) => {
    currentPath += `/${segment}`;
    items.push({
      '@type': 'ListItem',
      position: index + 2,
      name: breadcrumbNames[segment] || segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
      item: `${siteUrl}${currentPath}`,
    });
  });

  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items,
  };
}

const breadcrumbSchema = generateBreadcrumbs();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Deckyard" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0d4e36" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} - Deckyard`} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    {locales.filter(loc => loc !== locale).map((loc) => (
      <meta property="og:locale:alternate" content={loc} />
    ))}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${title} - Deckyard`} />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />

    <!-- Alternate language links for SEO -->
    <link rel="alternate" hreflang="x-default" href={new URL(pathWithoutLocale || '/', siteUrl).href} />
    {locales.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={new URL(loc === defaultLocale ? pathWithoutLocale || '/' : `/${loc}${pathWithoutLocale}`, siteUrl).href}
      />
    ))}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://sandbox.deckyard.eu" />
    <link rel="dns-prefetch" href="https://sandbox.deckyard.eu" />

    <link rel="stylesheet" href="/styles/index.css" />

    <!-- Additional page-specific head content -->
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('nav.skipToContent')}</a>

    <IconSprite />

    <SiteHeader locale={locale} currentPath={Astro.url.pathname} />

    <main id="main">
      <slot />
    </main>

    <SiteFooter locale={locale} />

    <script src="/app.js" defer></script>
  </body>
</html>
