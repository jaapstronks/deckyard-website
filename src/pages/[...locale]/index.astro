---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) return path;
  return `/${locale}${path}`;
}

const slideTypes = [
  { id: 'chart', name: 'Charts' },
  { id: 'kpiMetrics', name: 'KPI Metrics' },
  { id: 'timeline', name: 'Timeline' },
  { id: 'comparison', name: 'Comparison' },
  { id: 'funnel', name: 'Funnel' },
  { id: 'process', name: 'Process' },
  { id: 'poll', name: 'Live Poll' },
  { id: 'feedback', name: 'Feedback' },
  { id: 'imageText', name: 'Image + Text' },
  { id: 'gallery', name: 'Gallery' },
  { id: 'table', name: 'Data Table' },
  { id: 'iconCards', name: 'Icon Cards' },
  { id: 'quote', name: 'Quote' },
  { id: 'matrix', name: 'Matrix' },
  { id: 'pyramid', name: 'Pyramid' },
  { id: 'cycle', name: 'Cycle' },
];
---

<BaseLayout
  title={t('home.meta.title')}
  description={t('home.meta.description')}
  locale={locale}
>
  <!-- ============================================================
       HERO
       "A presentation platform that's actually yours"
       ============================================================ -->
  <section id="top" class="hero section-glow">
    <div class="container hero-inner">
      <div class="hero-copy" data-animate>
        <h1 set:html={t('home.hero.title')} />
        <p class="lead">{t('home.hero.lead')}</p>

        <div class="cta-row">
          <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
            {t('home.hero.trySandbox')}
          </a>
          <a class="btn btn-secondary btn-lg" href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noreferrer">
            {t('home.hero.viewOnGithub')}
          </a>
        </div>

        <ul class="badge-row" aria-label="Highlights">
          <li class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-map-pin"></use></svg> {t('home.hero.badges.hostedInFrance')}</li>
          <li class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-lock"></use></svg> {t('home.hero.badges.gdprNative')}</li>
          <li class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-house"></use></svg> {t('home.hero.badges.selfHostable')}</li>
          <li class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-book-open"></use></svg> {t('home.hero.badges.mitLicensed')}</li>
        </ul>
      </div>

      <div class="hero-proof" aria-label="Product preview" data-animate>
        <!--
          TODO: Embed a live Deckyard presentation here.
          Recommended deck: A short 5–7 slide "product tour" deck that showcases
          different slide types (title, KPIs, chart, image+text, poll, quote, payoff).
          Self-referential: a Deckyard presentation about Deckyard.

          When ready, replace the <img> below with:
          <iframe
            class="embed-iframe"
            src="https://app.deckyard.eu/embed/DEMO_DECK_ID"
            title="Deckyard demo presentation"
            data-js="heroEmbed"
            allowfullscreen
          ></iframe>
          <div class="embed-loading">
            <div class="spinner"></div>
            <span class="embed-loading-text">Loading presentation…</span>
          </div>
        -->
        <div class="browser-mockup">
          <div class="browser-mockup-bar">
            <span class="browser-mockup-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </span>
            <span class="browser-mockup-url">sandbox.deckyard.eu</span>
          </div>
          <div class="browser-mockup-body">
            <img
              src="/images/deckyard-editor-preview.png"
              alt={t('home.hero.screenshotAlt')}
              class="hero-screenshot"
              loading="eager"
            />
          </div>
        </div>
        <p class="fineprint">
          {t('home.hero.screenshotCaption')} <a href="https://sandbox.deckyard.eu" target="_blank" rel="noreferrer">{t('home.hero.tryItYourself')}</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROBLEM/SOLUTION: "Presentations are still broken"
       Problem statement → Solution pivot → Video demo → Supporting points
       ============================================================ -->
  <section id="problem" class="section section-glow">
    <div class="container">
      <div class="section-header" data-animate>
        <h2>{t('home.problem.title')}</h2>
        <p class="section-lead">{t('home.problem.pain')}</p>
      </div>

      <div class="tour" data-animate>
        <article class="tour-item">
          <div class="tour-visual">
            <div class="visual-frame">
              <img src="/images/demo-prompt-to-deck.png" alt={t('home.problem.video.alt')} class="visual-screenshot" loading="lazy" />
            </div>
          </div>
          <div class="tour-copy">
            <h3>{t('home.problem.solutionTitle')}</h3>
            <p>{t('home.problem.solution')}</p>
            <p class="fineprint">{t('home.problem.video.caption')}</p>
          </div>
        </article>
      </div>

      <!-- Supporting points -->
      <div class="grid cards-3 problem-cards" data-animate-stagger>
        <article class="card">
          <div class="card-icon" aria-hidden="true">
            <svg class="icon"><use href="#icon-users"></use></svg>
          </div>
          <h3>{t('home.problem.roles.title')}</h3>
          <p>{t('home.problem.roles.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true">
            <svg class="icon"><use href="#icon-database"></use></svg>
          </div>
          <h3>{t('home.problem.liveData.title')}</h3>
          <p>{t('home.problem.liveData.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true">
            <svg class="icon"><use href="#icon-sparkle"></use></svg>
          </div>
          <h3>{t('home.problem.generation.title')}</h3>
          <p>{t('home.problem.generation.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRODUCT SHOWCASE: "Everything you need, nothing you don't"
       Slide type thumbnail gallery — visual proof of 44 types
       ============================================================ -->
  <section id="showcase" class="section section-alt">
    <div class="container">
      <div class="section-header" data-animate>
        <h2>{t('home.showcase.title')}</h2>
        <p class="section-lead">{t('home.showcase.lead')}</p>
      </div>

      <div class="slide-type-grid" data-animate-stagger>
        {slideTypes.map(type => (
          <div class="slide-type-card">
            <div class="slide-type-thumb">
              <img
                class="slide-type-img"
                src={`/images/slide-types/${type.id}.png`}
                alt={type.name}
                loading="lazy"
              />
            </div>
            <p class="slide-type-name">{type.name}</p>
          </div>
        ))}
        <a class="slide-type-card slide-type-more" href={getLocalePath('/features')}>
          <div class="slide-type-thumb slide-type-thumb-more">
            <span class="more-count">+28</span>
            <span class="more-label">more types</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INTERACTIONS: "Engage your audience without switching tools"
       Mentimeter alternative angle — split layout with feature pills
       ============================================================ -->
  <section id="interactions" class="section section-glow">
    <div class="container">
      <div class="tour" data-animate>
        <article class="tour-item">
          <div class="tour-visual">
            <div class="visual-frame">
              <!-- TODO: Replace with a screenshot showing a live poll with simulated audience responses -->
              <img src="/images/marketing/poll-slide-marketing.png" alt="Live poll slide with real-time audience responses" class="visual-screenshot" loading="lazy" />
            </div>
          </div>
          <div class="tour-copy">
            <h2>{t('home.interactions.title')}</h2>
            <p class="section-lead">{t('home.interactions.lead')}</p>
            <p>{t('home.interactions.description')}</p>
            <div class="badge-row feature-pills">
              <span class="chip">{t('home.interactions.polls')}</span>
              <span class="chip">{t('home.interactions.qna')}</span>
              <span class="chip">{t('home.interactions.feedback')}</span>
              <span class="chip">{t('home.interactions.likert')}</span>
              <span class="chip">{t('home.interactions.quizzes')}</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       AI: "AI that actually works — on your terms"
       65% enthusiasm / 35% control-reassurance balance
       ============================================================ -->
  <section id="ai" class="section section-alt">
    <div class="container">
      <div class="section-header" data-animate>
        <h2>{t('home.ai.title')}</h2>
        <p class="section-lead">{t('home.ai.lead')}</p>
      </div>

      <!-- Capability strip -->
      <div class="badge-row capability-strip" data-animate>
        <span class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-sparkle"></use></svg> {t('home.ai.capabilities.generate')}</span>
        <span class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-file-text"></use></svg> {t('home.ai.capabilities.convert')}</span>
        <span class="badge"><svg class="badge-icon" aria-hidden="true"><use href="#icon-globe"></use></svg> {t('home.ai.capabilities.translate')}</span>
      </div>

      <div class="tour" data-animate>
        <article class="tour-item">
          <div class="tour-visual">
            <div class="visual-frame">
              <img src="/images/screenshots/ai-slide-wizard.png" alt="AI slide wizard generating presentation content from a prompt" class="visual-screenshot" loading="lazy" />
            </div>
          </div>
          <div class="tour-copy">
            <h3 class="h3-with-icon">
              <span class="icon-wrap" aria-hidden="true"><svg class="icon"><use href="#icon-lock"></use></svg></span>
              {t('home.ai.byoKeys.title')}
            </h3>
            <p>{t('home.ai.byoKeys.description')}</p>

            <h3 class="h3-with-icon">
              <span class="icon-wrap" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></span>
              {t('home.ai.reliable.title')}
            </h3>
            <p>{t('home.ai.reliable.description')}</p>
          </div>
        </article>
      </div>

      <div class="callout ai-control-callout" data-animate>
        <p><strong>{t('home.ai.control.title')}:</strong> {t('home.ai.control.description')}</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SOVEREIGNTY: "Your infrastructure, or ours"
       Dark section — two-path layout + docker command + trust line
       ============================================================ -->
  <section id="sovereignty" class="section section-deep">
    <div class="container">
      <div class="section-header" data-animate>
        <h2>{t('home.sovereignty.title')}</h2>
        <p class="section-lead">{t('home.sovereignty.lead')}</p>
      </div>

      <div class="deploy-options" data-animate-stagger>
        <article class="deploy-card deploy-card-highlight">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('home.sovereignty.cloud.title')}</h3>
          <ul class="bullets">
            <li>{t('home.sovereignty.cloud.hosted')}</li>
            <li>{t('home.sovereignty.cloud.managed')}</li>
            <li>{t('home.sovereignty.cloud.free')}</li>
            <li>{t('home.sovereignty.cloud.gdpr')}</li>
          </ul>
          <a class="btn btn-secondary" href={getLocalePath('/pricing')}>{t('home.sovereignty.cloud.cta')}</a>
        </article>

        <article class="deploy-card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-database"></use></svg></div>
          <h3>{t('home.sovereignty.selfHost.title')}</h3>
          <ul class="bullets">
            <li>{t('home.sovereignty.selfHost.servers')}</li>
            <li>{t('home.sovereignty.selfHost.control')}</li>
            <li>{t('home.sovereignty.selfHost.docker')}</li>
            <li>{t('home.sovereignty.selfHost.free')}</li>
          </ul>
          <div class="code-block">
            <code>{t('home.sovereignty.selfHost.command')}</code>
          </div>
          <a class="btn btn-secondary" href={getLocalePath('/self-hosting')}>{t('home.sovereignty.selfHost.cta')}</a>
        </article>
      </div>

      <p class="trust-line" data-animate>
        <svg class="trust-icon" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        {t('home.sovereignty.trust')}
      </p>
    </div>
  </section>

  <!-- ============================================================
       OPEN PLATFORM: "Open source and built to extend"
       4-card grid — GitHub, API, MCP, open formats
       ============================================================ -->
  <section id="open-platform" class="section section-glow">
    <div class="container">
      <div class="section-header" data-animate>
        <h2>{t('home.openPlatform.title')}</h2>
        <p class="section-lead">{t('home.openPlatform.lead')}</p>
      </div>

      <div class="grid cards" data-animate-stagger>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('home.openPlatform.opensource.title')}</h3>
          <p>{t('home.openPlatform.opensource.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('home.openPlatform.api.title')}</h3>
          <p>{t('home.openPlatform.api.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('home.openPlatform.mcp.title')}</h3>
          <p>{t('home.openPlatform.mcp.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('home.openPlatform.formats.title')}</h3>
          <p>{t('home.openPlatform.formats.description')}</p>
        </article>
      </div>

      <div class="api-snippet" data-animate>
        <div class="api-snippet-header">
          <span class="api-snippet-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
          <span class="api-snippet-lang">JavaScript</span>
        </div>
        <pre class="api-snippet-code"><code><span class="code-comment">// Create a presentation via API</span>
<span class="code-keyword">const</span> deck = <span class="code-keyword">await</span> deckyard.presentations.<span class="code-fn">create</span>({'{'}
  title: <span class="code-string">"Q4 Report"</span>,
  template: <span class="code-string">"corporate"</span>,
  slides: [{'{'} type: <span class="code-string">"kpi"</span>, data: metrics {'}'}]
{'}'});</code></pre>
      </div>

      <div class="cta-row cta-center" data-animate>
        <a class="btn btn-primary" href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noreferrer">{t('home.openPlatform.viewOnGithub')}</a>
        <a class="btn btn-secondary" href="/docs/developer/">{t('home.openPlatform.apiDocs')}</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SOCIAL PROOF
       Early-stage: founder intro + trust badges
       Later: logos, quotes, usage stats
       ============================================================ -->
  <section class="section section-alt">
    <div class="container">
      <div class="founder-block" data-animate>
        <p class="founder-origin">{t('home.proof.origin')}</p>
        <p class="founder-name"><strong>{t('home.proof.builtBy')} {t('home.proof.founderName')}</strong></p>
        <p class="founder-role">{t('home.proof.founderRole')}</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA: "Ready to try it?"
       Three action paths: sandbox, GitHub, self-host guide
       ============================================================ -->
  <section class="section section-cta">
    <div class="container">
      <div data-animate>
        <h2>{t('home.cta.title')}</h2>
        <p class="section-lead">{t('home.cta.lead')}</p>
      </div>

      <div class="cta-row cta-center" data-animate>
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('home.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href="https://github.com/jaapstronks/deckyard" target="_blank" rel="noreferrer">
          {t('home.cta.viewOnGithub')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>
          {t('home.cta.selfHost')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
