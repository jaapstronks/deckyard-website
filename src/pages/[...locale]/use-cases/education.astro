---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('useCasesEducation.meta.title')}
  description={t('useCasesEducation.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('useCasesEducation.hero.title')}</h1>
      <p class="lead">{t('useCasesEducation.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('useCasesEducation.whyEducators.title')}</h2>
      <p class="section-lead">{t('useCasesEducation.whyEducators.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('useCasesEducation.whyEducators.studentPrivacy.title')}</h3>
          <p>{t('useCasesEducation.whyEducators.studentPrivacy.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('useCasesEducation.whyEducators.engagement.title')}</h3>
          <p>{t('useCasesEducation.whyEducators.engagement.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-database"></use></svg></div>
          <h3>{t('useCasesEducation.whyEducators.noBudget.title')}</h3>
          <p>{t('useCasesEducation.whyEducators.noBudget.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('useCasesEducation.whyEducators.institutional.title')}</h3>
          <p>{t('useCasesEducation.whyEducators.institutional.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesEducation.classroom.title')}</h2>
      <p class="section-lead">{t('useCasesEducation.classroom.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('useCasesEducation.classroom.checkUnderstanding.title')}</h3>
          <p>{t('useCasesEducation.classroom.checkUnderstanding.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesEducation.classroom.qna.title')}</h3>
          <p>{t('useCasesEducation.classroom.qna.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('useCasesEducation.classroom.quizzes.title')}</h3>
          <p>{t('useCasesEducation.classroom.quizzes.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('useCasesEducation.classroom.feedback.title')}</h3>
          <p>{t('useCasesEducation.classroom.feedback.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesEducation.privacy.title')}</h2>
      <p class="section-lead">{t('useCasesEducation.privacy.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesEducation.privacy.noTracking')}</strong></li>
        <li><strong>{t('useCasesEducation.privacy.anonymousResponses')}</strong></li>
        <li><strong>{t('useCasesEducation.privacy.noAccounts')}</strong></li>
        <li><strong>{t('useCasesEducation.privacy.euHosted')}</strong></li>
        <li><strong>{t('useCasesEducation.privacy.selfHost')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesEducation.aiForEducators.title')}</h2>
      <p class="section-lead">{t('useCasesEducation.aiForEducators.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesEducation.aiForEducators.lessonPlans')}</strong></li>
        <li><strong>{t('useCasesEducation.aiForEducators.documentConversion')}</strong></li>
        <li><strong>{t('useCasesEducation.aiForEducators.byoKeys')}</strong></li>
        <li><strong>{t('useCasesEducation.aiForEducators.optional')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesEducation.institutionalDeployment.title')}</h2>
      <p class="section-lead">{t('useCasesEducation.institutionalDeployment.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesEducation.institutionalDeployment.campus')}</strong></li>
        <li><strong>{t('useCasesEducation.institutionalDeployment.lms')}</strong></li>
        <li><strong>{t('useCasesEducation.institutionalDeployment.sso')}</strong></li>
        <li><strong>{t('useCasesEducation.institutionalDeployment.compliance')}</strong></li>
      </ul>

      <p>
        <a class="btn btn-secondary" href={getLocalePath('/self-hosting')}>{t('useCasesEducation.institutionalDeployment.cta')}</a>
      </p>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('useCasesEducation.cta.title')}</h2>
      <p class="section-lead">{t('useCasesEducation.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('useCasesEducation.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href="mailto:hello@deckyard.eu">
          {t('useCasesEducation.cta.contactEducation')}
        </a>
      </div>
      <p class="section-note">{t('useCasesEducation.cta.discount')}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .section-note {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--gray-600);
  }
</style>
