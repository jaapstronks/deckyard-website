---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('useCasesGovernment.meta.title')}
  description={t('useCasesGovernment.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('useCasesGovernment.hero.title')}</h1>
      <p class="lead">{t('useCasesGovernment.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('useCasesGovernment.whyDifferent.title')}</h2>
      <p class="section-lead">{t('useCasesGovernment.whyDifferent.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesGovernment.whyDifferent.gdpr')}</strong></li>
        <li><strong>{t('useCasesGovernment.whyDifferent.accessibility')}</strong></li>
        <li><strong>{t('useCasesGovernment.whyDifferent.interoperability')}</strong></li>
        <li><strong>{t('useCasesGovernment.whyDifferent.procurement')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('useCasesGovernment.requirements.title')}</h2>
      <p class="section-lead">{t('useCasesGovernment.requirements.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-map-pin"></use></svg></div>
          <h3>{t('useCasesGovernment.requirements.euData.title')}</h3>
          <p>{t('useCasesGovernment.requirements.euData.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('useCasesGovernment.requirements.gdprNative.title')}</h3>
          <p>{t('useCasesGovernment.requirements.gdprNative.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('useCasesGovernment.requirements.openStandards.title')}</h3>
          <p>{t('useCasesGovernment.requirements.openStandards.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesGovernment.requirements.wcag.title')}</h3>
          <p>{t('useCasesGovernment.requirements.wcag.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('useCasesGovernment.requirements.mitLicense.title')}</h3>
          <p>{t('useCasesGovernment.requirements.mitLicense.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-lock"></use></svg></div>
          <h3>{t('useCasesGovernment.requirements.dpa.title')}</h3>
          <p>{t('useCasesGovernment.requirements.dpa.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesGovernment.citizenEngagement.title')}</h2>
      <p class="section-lead">{t('useCasesGovernment.citizenEngagement.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('useCasesGovernment.citizenEngagement.townHalls.title')}</h3>
          <p>{t('useCasesGovernment.citizenEngagement.townHalls.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesGovernment.citizenEngagement.consultations.title')}</h3>
          <p>{t('useCasesGovernment.citizenEngagement.consultations.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('useCasesGovernment.citizenEngagement.training.title')}</h3>
          <p>{t('useCasesGovernment.citizenEngagement.training.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('useCasesGovernment.citizenEngagement.councils.title')}</h3>
          <p>{t('useCasesGovernment.citizenEngagement.councils.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesGovernment.procurement.title')}</h2>
      <p class="section-lead">{t('useCasesGovernment.procurement.lead')}</p>

      <div class="data-table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>{t('useCasesGovernment.procurement.requirement')}</th>
              <th>{t('useCasesGovernment.procurement.deckyard')}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('useCasesGovernment.procurement.dataResidency')}</td>
              <td class="yes">{t('useCasesGovernment.procurement.dataResidencyAnswer')}</td>
            </tr>
            <tr>
              <td>{t('useCasesGovernment.procurement.gdprCompliance')}</td>
              <td class="yes">{t('useCasesGovernment.procurement.gdprComplianceAnswer')}</td>
            </tr>
            <tr>
              <td>{t('useCasesGovernment.procurement.dpaAvailable')}</td>
              <td class="yes">{t('useCasesGovernment.procurement.dpaAvailableAnswer')}</td>
            </tr>
            <tr>
              <td>{t('useCasesGovernment.procurement.accessibilityCompliance')}</td>
              <td class="yes">{t('useCasesGovernment.procurement.accessibilityComplianceAnswer')}</td>
            </tr>
            <tr>
              <td>{t('useCasesGovernment.procurement.exitStrategy')}</td>
              <td class="yes">{t('useCasesGovernment.procurement.exitStrategyAnswer')}</td>
            </tr>
            <tr>
              <td>{t('useCasesGovernment.procurement.pricing')}</td>
              <td class="yes">{t('useCasesGovernment.procurement.pricingAnswer')}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesGovernment.selfHosting.title')}</h2>
      <p class="section-lead">{t('useCasesGovernment.selfHosting.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesGovernment.selfHosting.internalNetworks')}</strong></li>
        <li><strong>{t('useCasesGovernment.selfHosting.governmentCloud')}</strong></li>
        <li><strong>{t('useCasesGovernment.selfHosting.auditTrails')}</strong></li>
        <li><strong>{t('useCasesGovernment.selfHosting.noExternal')}</strong></li>
      </ul>

      <p>
        <a class="btn btn-secondary" href={getLocalePath('/self-hosting')}>{t('useCasesGovernment.selfHosting.cta')}</a>
      </p>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('useCasesGovernment.cta.title')}</h2>
      <p class="section-lead">{t('useCasesGovernment.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="mailto:hello@deckyard.eu">
          {t('useCasesGovernment.cta.requestDocumentation')}
        </a>
        <a class="btn btn-secondary btn-lg" href="mailto:hello@deckyard.eu">
          {t('useCasesGovernment.cta.scheduleDemo')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
