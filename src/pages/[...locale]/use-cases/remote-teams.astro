---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('useCasesRemoteTeams.meta.title')}
  description={t('useCasesRemoteTeams.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('useCasesRemoteTeams.hero.title')}</h1>
      <p class="lead">{t('useCasesRemoteTeams.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('useCasesRemoteTeams.challenges.title')}</h2>
      <p class="section-lead">{t('useCasesRemoteTeams.challenges.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.challenges.engagement.title')}</h3>
          <p>{t('useCasesRemoteTeams.challenges.engagement.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.challenges.timezones.title')}</h3>
          <p>{t('useCasesRemoteTeams.challenges.timezones.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.challenges.feedback.title')}</h3>
          <p>{t('useCasesRemoteTeams.challenges.feedback.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-link"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.challenges.tools.title')}</h3>
          <p>{t('useCasesRemoteTeams.challenges.tools.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesRemoteTeams.solutions.title')}</h2>
      <p class="section-lead">{t('useCasesRemoteTeams.solutions.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-link"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.solutions.followAlong.title')}</h3>
          <p>{t('useCasesRemoteTeams.solutions.followAlong.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.solutions.livePolls.title')}</h3>
          <p>{t('useCasesRemoteTeams.solutions.livePolls.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.solutions.qna.title')}</h3>
          <p>{t('useCasesRemoteTeams.solutions.qna.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('useCasesRemoteTeams.solutions.asyncAccess.title')}</h3>
          <p>{t('useCasesRemoteTeams.solutions.asyncAccess.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesRemoteTeams.useCases.title')}</h2>
      <p class="section-lead">{t('useCasesRemoteTeams.useCases.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesRemoteTeams.useCases.allHands')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.useCases.teamRetros')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.useCases.onboarding')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.useCases.workshops')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.useCases.clientMeetings')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesRemoteTeams.asyncFeatures.title')}</h2>
      <p class="section-lead">{t('useCasesRemoteTeams.asyncFeatures.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesRemoteTeams.asyncFeatures.shareableLinks')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.asyncFeatures.embedHtml')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.asyncFeatures.exportPdf')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.asyncFeatures.responseCollection')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesRemoteTeams.integration.title')}</h2>
      <p class="section-lead">{t('useCasesRemoteTeams.integration.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesRemoteTeams.integration.videoConf')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.integration.webBased')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.integration.noPlugins')}</strong></li>
        <li><strong>{t('useCasesRemoteTeams.integration.mobileResponsive')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('useCasesRemoteTeams.cta.title')}</h2>
      <p class="section-lead">{t('useCasesRemoteTeams.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('useCasesRemoteTeams.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/pricing')}>
          {t('useCasesRemoteTeams.cta.viewPricing')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
