---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('useCasesNonprofits.meta.title')}
  description={t('useCasesNonprofits.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('useCasesNonprofits.hero.title')}</h1>
      <p class="lead">{t('useCasesNonprofits.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('useCasesNonprofits.whyNonprofits.title')}</h2>
      <p class="section-lead">{t('useCasesNonprofits.whyNonprofits.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-database"></use></svg></div>
          <h3>{t('useCasesNonprofits.whyNonprofits.budgetFriendly.title')}</h3>
          <p>{t('useCasesNonprofits.whyNonprofits.budgetFriendly.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('useCasesNonprofits.whyNonprofits.donorPrivacy.title')}</h3>
          <p>{t('useCasesNonprofits.whyNonprofits.donorPrivacy.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('useCasesNonprofits.whyNonprofits.valuesAligned.title')}</h3>
          <p>{t('useCasesNonprofits.whyNonprofits.valuesAligned.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesNonprofits.whyNonprofits.engagement.title')}</h3>
          <p>{t('useCasesNonprofits.whyNonprofits.engagement.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesNonprofits.useCases.title')}</h2>
      <p class="section-lead">{t('useCasesNonprofits.useCases.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('useCasesNonprofits.useCases.fundraising.title')}</h3>
          <p>{t('useCasesNonprofits.useCases.fundraising.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('useCasesNonprofits.useCases.boardMeetings.title')}</h3>
          <p>{t('useCasesNonprofits.useCases.boardMeetings.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('useCasesNonprofits.useCases.volunteerTraining.title')}</h3>
          <p>{t('useCasesNonprofits.useCases.volunteerTraining.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('useCasesNonprofits.useCases.communityEvents.title')}</h3>
          <p>{t('useCasesNonprofits.useCases.communityEvents.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('useCasesNonprofits.pricing.title')}</h2>
      <p class="section-lead">{t('useCasesNonprofits.pricing.lead')}</p>

      <div class="data-table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>{t('useCasesNonprofits.pricing.option')}</th>
              <th>{t('useCasesNonprofits.pricing.cost')}</th>
              <th>{t('useCasesNonprofits.pricing.bestFor')}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>{t('useCasesNonprofits.pricing.selfHosted')}</strong></td>
              <td class="yes">{t('useCasesNonprofits.pricing.free')}</td>
              <td>{t('useCasesNonprofits.pricing.selfHostedBestFor')}</td>
            </tr>
            <tr>
              <td><strong>{t('useCasesNonprofits.pricing.nonprofitPro')}</strong></td>
              <td class="yes">{t('useCasesNonprofits.pricing.nonprofitProCost')}</td>
              <td>{t('useCasesNonprofits.pricing.nonprofitProBestFor')}</td>
            </tr>
            <tr>
              <td><strong>{t('useCasesNonprofits.pricing.nonprofitTeam')}</strong></td>
              <td class="yes">{t('useCasesNonprofits.pricing.nonprofitTeamCost')}</td>
              <td>{t('useCasesNonprofits.pricing.nonprofitTeamBestFor')}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p>{t('useCasesNonprofits.pricing.eligibility')}</p>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('useCasesNonprofits.valuesAlignment.title')}</h2>
      <p class="section-lead">{t('useCasesNonprofits.valuesAlignment.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('useCasesNonprofits.valuesAlignment.openSource')}</strong></li>
        <li><strong>{t('useCasesNonprofits.valuesAlignment.privacyFirst')}</strong></li>
        <li><strong>{t('useCasesNonprofits.valuesAlignment.noVendorLockin')}</strong></li>
        <li><strong>{t('useCasesNonprofits.valuesAlignment.sustainable')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('useCasesNonprofits.cta.title')}</h2>
      <p class="section-lead">{t('useCasesNonprofits.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="mailto:hello@deckyard.eu">
          {t('useCasesNonprofits.cta.applyDiscount')}
        </a>
        <a class="btn btn-secondary btn-lg" href="https://sandbox.deckyard.eu">
          {t('useCasesNonprofits.cta.trySandbox')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
