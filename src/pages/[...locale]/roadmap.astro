---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('roadmap.meta.title')}
  description={t('roadmap.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('roadmap.hero.title')}</h1>
      <p class="lead">{t('roadmap.hero.lead')}</p>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('roadmap.philosophy.title')}</h2>
      <p>{t('roadmap.philosophy.paragraph1')}</p>
      <p>{t('roadmap.philosophy.paragraph2')}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('roadmap.inProgress.title')}</h2>
      <p class="section-lead">{t('roadmap.inProgress.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('roadmap.inProgress.sso.title')}</h3>
          <p>{t('roadmap.inProgress.sso.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('roadmap.inProgress.pptxImport.title')}</h3>
          <p>{t('roadmap.inProgress.pptxImport.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('roadmap.inProgress.moreLanguages.title')}</h3>
          <p>{t('roadmap.inProgress.moreLanguages.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('roadmap.inProgress.aiImprovements.title')}</h3>
          <p>{t('roadmap.inProgress.aiImprovements.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('roadmap.planned.title')}</h2>
      <p class="section-lead">{t('roadmap.planned.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('roadmap.planned.realTimeCollab.title')}</h3>
          <p>{t('roadmap.planned.realTimeCollab.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-link"></use></svg></div>
          <h3>{t('roadmap.planned.apiAccess.title')}</h3>
          <p>{t('roadmap.planned.apiAccess.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('roadmap.planned.analytics.title')}</h3>
          <p>{t('roadmap.planned.analytics.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-database"></use></svg></div>
          <h3>{t('roadmap.planned.templateLibrary.title')}</h3>
          <p>{t('roadmap.planned.templateLibrary.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('roadmap.planned.webhooks.title')}</h3>
          <p>{t('roadmap.planned.webhooks.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-eye-slash"></use></svg></div>
          <h3>{t('roadmap.planned.offlineMode.title')}</h3>
          <p>{t('roadmap.planned.offlineMode.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('roadmap.recentlyShipped.title')}</h2>
      <p class="section-lead">{t('roadmap.recentlyShipped.lead')}</p>

      <ul class="bullets">
        <li><strong>{t('roadmap.recentlyShipped.aiGeneration')}</strong></li>
        <li><strong>{t('roadmap.recentlyShipped.customThemes')}</strong></li>
        <li><strong>{t('roadmap.recentlyShipped.wordClouds')}</strong></li>
        <li><strong>{t('roadmap.recentlyShipped.pdfExport')}</strong></li>
        <li><strong>{t('roadmap.recentlyShipped.followAlong')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('roadmap.requestFeature.title')}</h2>
      <p class="section-lead">{t('roadmap.requestFeature.lead')}</p>

      <ul class="bullets">
        <li>{t('roadmap.requestFeature.github')}</li>
        <li>{t('roadmap.requestFeature.discussions')}</li>
        <li>{t('roadmap.requestFeature.upvote')}</li>
      </ul>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('roadmap.cta.title')}</h2>
      <p class="section-lead">{t('roadmap.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://github.com/deckyard/deckyard/discussions" target="_blank" rel="noreferrer">
          {t('roadmap.cta.joinDiscussions')}
        </a>
        <a class="btn btn-secondary btn-lg" href="https://github.com/deckyard/deckyard/issues" target="_blank" rel="noreferrer">
          {t('roadmap.cta.viewIssues')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
