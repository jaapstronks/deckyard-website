---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('compareSlido.meta.title')}
  description={t('compareSlido.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('compareSlido.hero.title')}</h1>
      <p class="lead">{t('compareSlido.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('compareSlido.comparison.title')}</h2>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>Deckyard</th>
              <th>Slido</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('compareSlido.comparison.openSource')}</td>
              <td class="yes">✓ MIT license</td>
              <td class="no">✗ Proprietary (Cisco)</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.selfHosting')}</td>
              <td class="yes">✓ Docker deploy</td>
              <td class="no">✗ Cloud only</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.slideEditor')}</td>
              <td class="yes">✓ Full editor, 44 types</td>
              <td class="no">✗ Interactions only</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.livePolls')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.qna')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.wordClouds')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.quizzes')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.aiGeneration')}</td>
              <td class="yes">✓ BYO API keys</td>
              <td class="partial">Limited (paid)</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.euHosting')}</td>
              <td class="yes">✓ France (EU company)</td>
              <td class="partial">EU option (US company)</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.pricingModel')}</td>
              <td class="yes">Free / flat rate</td>
              <td class="no">Per-event / enterprise</td>
            </tr>
            <tr>
              <td>{t('compareSlido.comparison.ownership')}</td>
              <td class="yes">Independent</td>
              <td class="no">Cisco (since 2020)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('compareSlido.reasons.title')}</h2>

      <div class="reasons">
        <article class="reason">
          <h3>{t('compareSlido.reasons.ciscoAcquisition.title')}</h3>
          <p>{t('compareSlido.reasons.ciscoAcquisition.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlido.reasons.fullEditor.title')}</h3>
          <p>{t('compareSlido.reasons.fullEditor.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlido.reasons.pricing.title')}</h3>
          <p>{t('compareSlido.reasons.pricing.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlido.reasons.dataSovereignty.title')}</h3>
          <p>{t('compareSlido.reasons.dataSovereignty.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlido.reasons.openSource.title')}</h3>
          <p>{t('compareSlido.reasons.openSource.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('compareSlido.whenSlido.title')}</h2>
      <p>{t('compareSlido.whenSlido.lead')}</p>
      <ul class="bullets">
        <li><strong>{t('compareSlido.whenSlido.webex')}</strong></li>
        <li><strong>{t('compareSlido.whenSlido.enterprise')}</strong></li>
        <li><strong>{t('compareSlido.whenSlido.existingWorkflow')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('compareSlido.migration.title')}</h2>
      <p>{t('compareSlido.migration.lead')}</p>

      <ol class="numbered-list">
        <li><strong>{t('compareSlido.migration.step1')}</strong></li>
        <li><strong>{t('compareSlido.migration.step2')}</strong></li>
        <li><strong>{t('compareSlido.migration.step3')}</strong></li>
        <li><strong>{t('compareSlido.migration.step4')}</strong></li>
      </ol>

      <p>{t('compareSlido.migration.needHelp')} <a href="mailto:hello@deckyard.eu">{t('compareSlido.migration.contactUs')}</a></p>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('compareSlido.cta.title')}</h2>
      <p class="section-lead">{t('compareSlido.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('compareSlido.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>
          {t('compareSlido.cta.selfHostingGuide')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
