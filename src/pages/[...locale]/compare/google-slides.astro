---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('compareGoogleSlides.meta.title')}
  description={t('compareGoogleSlides.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('compareGoogleSlides.hero.title')}</h1>
      <p class="lead">{t('compareGoogleSlides.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('compareGoogleSlides.comparison.title')}</h2>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>Deckyard</th>
              <th>Google Slides</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('compareGoogleSlides.comparison.openSource')}</td>
              <td class="yes">✓ MIT license</td>
              <td class="no">✗ Proprietary</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.selfHosting')}</td>
              <td class="yes">✓ Docker deploy</td>
              <td class="no">✗ Cloud only</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.livePollsQna')}</td>
              <td class="yes">✓ Built-in</td>
              <td class="no">✗ Requires add-ons</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.audienceFeedback')}</td>
              <td class="yes">✓ Built-in</td>
              <td class="no">✗ Not available</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.aiGeneration')}</td>
              <td class="yes">✓ BYO API keys</td>
              <td class="partial">Gemini (locked in)</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.realTimeCollab')}</td>
              <td class="partial">Comments, sharing</td>
              <td class="yes">✓ Real-time co-editing</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.dataLocation')}</td>
              <td class="yes">EU/your servers</td>
              <td class="no">Google Cloud (US)</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.gdprCompliant')}</td>
              <td class="yes">✓ Native</td>
              <td class="partial">Requires DPA</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.offlineAccess')}</td>
              <td class="yes">✓ Self-hosted</td>
              <td class="partial">Limited</td>
            </tr>
            <tr>
              <td>{t('compareGoogleSlides.comparison.pricing')}</td>
              <td class="yes">Free (self-host)</td>
              <td class="yes">Free (with Google account)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('compareGoogleSlides.reasons.title')}</h2>

      <div class="reasons">
        <article class="reason">
          <h3>{t('compareGoogleSlides.reasons.audienceInteraction.title')}</h3>
          <p>{t('compareGoogleSlides.reasons.audienceInteraction.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareGoogleSlides.reasons.dataSovereignty.title')}</h3>
          <p>{t('compareGoogleSlides.reasons.dataSovereignty.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareGoogleSlides.reasons.googleFree.title')}</h3>
          <p>{t('compareGoogleSlides.reasons.googleFree.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareGoogleSlides.reasons.aiChoice.title')}</h3>
          <p>{t('compareGoogleSlides.reasons.aiChoice.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareGoogleSlides.reasons.openSource.title')}</h3>
          <p>{t('compareGoogleSlides.reasons.openSource.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('compareGoogleSlides.whenGoogleSlides.title')}</h2>
      <p>{t('compareGoogleSlides.whenGoogleSlides.lead')}</p>
      <ul class="bullets">
        <li><strong>{t('compareGoogleSlides.whenGoogleSlides.workspaceIntegration')}</strong></li>
        <li><strong>{t('compareGoogleSlides.whenGoogleSlides.realTimeCollab')}</strong></li>
        <li><strong>{t('compareGoogleSlides.whenGoogleSlides.simpleNeeds')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('compareGoogleSlides.migration.title')}</h2>
      <p>{t('compareGoogleSlides.migration.lead')}</p>

      <ol class="numbered-list">
        <li><strong>{t('compareGoogleSlides.migration.step1')}</strong></li>
        <li><strong>{t('compareGoogleSlides.migration.step2')}</strong></li>
        <li><strong>{t('compareGoogleSlides.migration.step3')}</strong></li>
        <li><strong>{t('compareGoogleSlides.migration.step4')}</strong></li>
      </ol>

      <p>{t('compareGoogleSlides.migration.needHelp')} <a href="mailto:hello@deckyard.eu">{t('compareGoogleSlides.migration.contactUs')}</a></p>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('compareGoogleSlides.cta.title')}</h2>
      <p class="section-lead">{t('compareGoogleSlides.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('compareGoogleSlides.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>
          {t('compareGoogleSlides.cta.selfHostingGuide')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
