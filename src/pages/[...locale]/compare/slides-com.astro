---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('compareSlidescom.meta.title')}
  description={t('compareSlidescom.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('compareSlidescom.hero.title')}</h1>
      <p class="lead">{t('compareSlidescom.hero.lead')}</p>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('compareSlidescom.respect.title')}</h2>
      <p class="section-lead">{t('compareSlidescom.respect.lead')}</p>
      <p>{t('compareSlidescom.respect.paragraph')}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('compareSlidescom.philosophy.title')}</h2>
      <p class="section-lead">{t('compareSlidescom.philosophy.intro')}</p>

      <div class="two-col philosophy-comparison">
        <div class="philosophy-card">
          <h3>{t('compareSlidescom.philosophy.slidescom.title')}</h3>
          <p>{t('compareSlidescom.philosophy.slidescom.description')}</p>
          <p class="best-for"><em>{t('compareSlidescom.philosophy.slidescom.bestFor')}</em></p>
        </div>
        <div class="philosophy-card philosophy-card-highlight">
          <h3>{t('compareSlidescom.philosophy.deckyard.title')}</h3>
          <p>{t('compareSlidescom.philosophy.deckyard.description')}</p>
          <p>{t('compareSlidescom.philosophy.deckyard.approach')}</p>
          <p><strong>{t('compareSlidescom.philosophy.deckyard.speed')}</strong></p>
          <p class="best-for"><em>{t('compareSlidescom.philosophy.deckyard.bestFor')}</em></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('compareSlidescom.slideTypes.title')}</h2>
      <p class="section-lead">{t('compareSlidescom.slideTypes.lead')}</p>
      <p>{t('compareSlidescom.slideTypes.aiAdvantage')}</p>
      <p>{t('compareSlidescom.slideTypes.categories')}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('compareSlidescom.comparison.title')}</h2>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>Deckyard</th>
              <th>Slides.com</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('compareSlidescom.comparison.openSource')}</td>
              <td class="yes">✓ MIT license</td>
              <td class="no">✗ Proprietary</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.selfHosting')}</td>
              <td class="yes">✓ Docker deploy</td>
              <td class="no">✗ Cloud only</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.webBasedEditor')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.livePollsQna')}</td>
              <td class="yes">✓ Built-in</td>
              <td class="no">✗ Not available</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.wordClouds')}</td>
              <td class="yes">✓</td>
              <td class="no">✗</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.audienceFeedback')}</td>
              <td class="yes">✓ Real-time</td>
              <td class="no">✗</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.aiGeneration')}</td>
              <td class="yes">✓ BYO API keys</td>
              <td class="no">✗</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.revealjsExport')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓ (built on it)</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.customCssThemes')}</td>
              <td class="yes">✓</td>
              <td class="yes">✓ (paid)</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.euHosting')}</td>
              <td class="yes">✓ France</td>
              <td class="no">US-based</td>
            </tr>
            <tr>
              <td>{t('compareSlidescom.comparison.pricing')}</td>
              <td class="yes">Free / flat rate</td>
              <td class="partial">$5–$19/mo</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('compareSlidescom.reasons.title')}</h2>

      <div class="reasons">
        <article class="reason">
          <h3>{t('compareSlidescom.reasons.audienceInteraction.title')}</h3>
          <p>{t('compareSlidescom.reasons.audienceInteraction.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlidescom.reasons.sovereignty.title')}</h3>
          <p>{t('compareSlidescom.reasons.sovereignty.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlidescom.reasons.aiChoice.title')}</h3>
          <p>{t('compareSlidescom.reasons.aiChoice.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlidescom.reasons.openSource.title')}</h3>
          <p>{t('compareSlidescom.reasons.openSource.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('compareSlidescom.reasons.euData.title')}</h3>
          <p>{t('compareSlidescom.reasons.euData.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('compareSlidescom.whenSlidescom.title')}</h2>
      <p>{t('compareSlidescom.whenSlidescom.lead')}</p>
      <ul class="bullets">
        <li><strong>{t('compareSlidescom.whenSlidescom.individual')}</strong></li>
        <li><strong>{t('compareSlidescom.whenSlidescom.revealjs')}</strong></li>
        <li><strong>{t('compareSlidescom.whenSlidescom.noThemeTeam')}</strong></li>
        <li><strong>{t('compareSlidescom.whenSlidescom.staticOnly')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('compareSlidescom.migration.title')}</h2>
      <p>{t('compareSlidescom.migration.lead')}</p>

      <ol class="numbered-list">
        <li><strong>{t('compareSlidescom.migration.step1')}</strong></li>
        <li><strong>{t('compareSlidescom.migration.step2')}</strong></li>
        <li><strong>{t('compareSlidescom.migration.step3')}</strong></li>
        <li><strong>{t('compareSlidescom.migration.step4')}</strong></li>
      </ol>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('compareSlidescom.cta.title')}</h2>
      <p class="section-lead">{t('compareSlidescom.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('compareSlidescom.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href="https://github.com/jaapstronks/deckyard">
          {t('compareSlidescom.cta.viewSource')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
