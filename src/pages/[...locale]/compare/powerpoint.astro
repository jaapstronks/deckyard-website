---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('comparePowerPoint.meta.title')}
  description={t('comparePowerPoint.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('comparePowerPoint.hero.title')}</h1>
      <p class="lead">{t('comparePowerPoint.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('comparePowerPoint.comparison.title')}</h2>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>Deckyard</th>
              <th>PowerPoint</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('comparePowerPoint.comparison.openSource')}</td>
              <td class="yes">✓ MIT license</td>
              <td class="no">✗ Proprietary</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.licenseCost')}</td>
              <td class="yes">Free</td>
              <td class="no">$12-22/user/month</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.livePollsQna')}</td>
              <td class="yes">✓ Built-in</td>
              <td class="no">✗ Not available</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.audienceFeedback')}</td>
              <td class="yes">✓ Built-in</td>
              <td class="no">✗ Not available</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.aiGeneration')}</td>
              <td class="yes">✓ BYO API keys</td>
              <td class="partial">Copilot (+$30/mo)</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.webBased')}</td>
              <td class="yes">✓ Yes</td>
              <td class="yes">✓ Yes (M365)</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.selfHosting')}</td>
              <td class="yes">✓ Docker deploy</td>
              <td class="no">✗ No</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.advancedAnimations')}</td>
              <td class="partial">Basic transitions</td>
              <td class="yes">✓ Full animation engine</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.offlineDesktop')}</td>
              <td class="partial">Self-hosted</td>
              <td class="yes">✓ Desktop app</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.comparison.exportFormats')}</td>
              <td class="yes">PDF, PPTX, HTML, PNG</td>
              <td class="yes">PDF, video, images</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('comparePowerPoint.reasons.title')}</h2>

      <div class="reasons">
        <article class="reason">
          <h3>{t('comparePowerPoint.reasons.noLicense.title')}</h3>
          <p>{t('comparePowerPoint.reasons.noLicense.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('comparePowerPoint.reasons.audienceInteraction.title')}</h3>
          <p>{t('comparePowerPoint.reasons.audienceInteraction.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('comparePowerPoint.reasons.aiChoice.title')}</h3>
          <p>{t('comparePowerPoint.reasons.aiChoice.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('comparePowerPoint.reasons.openSource.title')}</h3>
          <p>{t('comparePowerPoint.reasons.openSource.description')}</p>
        </article>

        <article class="reason">
          <h3>{t('comparePowerPoint.reasons.webFirst.title')}</h3>
          <p>{t('comparePowerPoint.reasons.webFirst.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('comparePowerPoint.costComparison.title')}</h2>
      <p>{t('comparePowerPoint.costComparison.lead')}</p>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>{t('comparePowerPoint.costComparison.scenario')}</th>
              <th>Deckyard</th>
              <th>PowerPoint</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('comparePowerPoint.costComparison.singleUser')}</td>
              <td class="yes">€0/mo (self-host)</td>
              <td class="no">$12.50/mo (M365 Personal)</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.costComparison.team10')}</td>
              <td class="yes">€49/mo (Team plan)</td>
              <td class="no">$125/mo (Business Basic)</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.costComparison.team50')}</td>
              <td class="yes">€49/mo (Team plan)</td>
              <td class="no">$625/mo (Business Basic)</td>
            </tr>
            <tr>
              <td>{t('comparePowerPoint.costComparison.withAi')}</td>
              <td class="yes">~€0.03/deck (API cost)</td>
              <td class="no">+$30/user/mo (Copilot)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('comparePowerPoint.whenPowerPoint.title')}</h2>
      <p>{t('comparePowerPoint.whenPowerPoint.lead')}</p>
      <ul class="bullets">
        <li><strong>{t('comparePowerPoint.whenPowerPoint.m365Investment')}</strong></li>
        <li><strong>{t('comparePowerPoint.whenPowerPoint.advancedAnimations')}</strong></li>
        <li><strong>{t('comparePowerPoint.whenPowerPoint.desktopWorkflow')}</strong></li>
        <li><strong>{t('comparePowerPoint.whenPowerPoint.enterpriseIt')}</strong></li>
      </ul>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('comparePowerPoint.migration.title')}</h2>
      <p>{t('comparePowerPoint.migration.lead')}</p>

      <ol class="numbered-list">
        <li><strong>{t('comparePowerPoint.migration.step1')}</strong></li>
        <li><strong>{t('comparePowerPoint.migration.step2')}</strong></li>
        <li><strong>{t('comparePowerPoint.migration.step3')}</strong></li>
        <li><strong>{t('comparePowerPoint.migration.step4')}</strong></li>
      </ol>

      <p>{t('comparePowerPoint.migration.pptxSupport')}</p>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('comparePowerPoint.cta.title')}</h2>
      <p class="section-lead">{t('comparePowerPoint.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('comparePowerPoint.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>
          {t('comparePowerPoint.cta.selfHostingGuide')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
