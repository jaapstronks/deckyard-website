---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}

// Slide type definitions with categories
// Image files are in /images/slide-types/{id}.png
const slideTypes = [
  // Data & Visualization
  { id: 'chart', category: 'data', hasImage: true },
  { id: 'kpiMetrics', category: 'data', hasImage: true },
  { id: 'table', category: 'data', hasImage: true },
  { id: 'funnel', category: 'data', hasImage: true },
  { id: 'pyramid', category: 'data', hasImage: true },
  { id: 'timeline', category: 'data', hasImage: true },
  { id: 'matrix', category: 'data', hasImage: true },
  { id: 'agenda', category: 'data', hasImage: true },
  { id: 'cycle', category: 'data', hasImage: true },
  { id: 'process', category: 'data', hasImage: true },
  { id: 'comparison', category: 'data', hasImage: true },
  // Interactive
  { id: 'poll', category: 'interactive', hasImage: true },
  { id: 'likert', category: 'interactive', hasImage: true },
  { id: 'likertSlider', category: 'interactive', hasImage: true },
  { id: 'feedback', category: 'interactive', hasImage: true },
  { id: 'followInvite', category: 'interactive', hasImage: true },
  // Content Cards
  { id: 'cardStack', category: 'cards', hasImage: true },
  { id: 'iconCards', category: 'cards', hasImage: true },
  { id: 'fourCards', category: 'cards', hasImage: true },
  { id: 'teamCards', category: 'cards', hasImage: true },
  { id: 'logoWall', category: 'cards', hasImage: true },
  { id: 'gallery', category: 'cards', hasImage: true },
  { id: 'partnerSplit', category: 'cards', hasImage: true },
  // Media
  { id: 'image', category: 'media', hasImage: true },
  { id: 'imageText', category: 'media', hasImage: true },
  { id: 'imageBlocks', category: 'media', hasImage: true },
  { id: 'video', category: 'media', hasImage: true },
  { id: 'embed', category: 'media', hasImage: true },
  // Structure
  { id: 'title', category: 'structure', hasImage: true },
  { id: 'chapter', category: 'structure', hasImage: true },
  { id: 'sectionTitle', category: 'structure', hasImage: true },
  { id: 'content', category: 'structure', hasImage: true },
  { id: 'contentColumns', category: 'structure', hasImage: true },
  { id: 'textBlocks', category: 'structure', hasImage: true },
  { id: 'quote', category: 'structure', hasImage: true },
  { id: 'list', category: 'structure', hasImage: true },
  { id: 'payoff', category: 'structure', hasImage: true },
];

const categories = ['all', 'data', 'interactive', 'cards', 'media', 'structure'];
---

<BaseLayout
  title={t('featuresSlideTypes.meta.title')}
  description={t('featuresSlideTypes.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/features')}>{t('featuresSlideTypes.hero.backToFeatures')}</a></p>
      <h1>{t('featuresSlideTypes.hero.title')}</h1>
      <p class="lead">{t('featuresSlideTypes.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="category-tabs" data-js="categoryTabs">
        {categories.map((cat, i) => (
          <button
            class:list={['category-tab', { 'is-active': i === 0 }]}
            data-category={cat}
          >
            {t(`featuresSlideTypes.categories.${cat}`)}
          </button>
        ))}
      </div>

      <div class="slide-type-grid" data-js="slideTypeGrid">
        {slideTypes.map(type => (
          <article class="slide-type-card" data-category={type.category}>
            <div class="slide-type-thumb">
              {type.hasImage ? (
                <img
                  src={`/images/slide-types/${type.id}.png`}
                  alt={t(`featuresSlideTypes.types.${type.id}.name`)}
                  class="slide-type-img"
                  loading="lazy"
                />
              ) : (
                <div class="slide-type-placeholder">{t(`featuresSlideTypes.types.${type.id}.name`)}</div>
              )}
            </div>
            <h3 class="slide-type-name">{t(`featuresSlideTypes.types.${type.id}.name`)}</h3>
            <p class="slide-type-desc">{t(`featuresSlideTypes.types.${type.id}.desc`)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('featuresSlideTypes.cta.title')}</h2>
      <p class="section-lead">{t('featuresSlideTypes.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('featuresSlideTypes.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href="/docs/">
          {t('featuresSlideTypes.cta.readDocs')}
        </a>
      </div>
    </div>
  </section>

  <script>
    // Category filtering
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('[data-category]');
      const cards = document.querySelectorAll('.slide-type-card');

      document.querySelector('[data-js="categoryTabs"]')?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.category-tab') as HTMLElement;
        if (!btn) return;

        const category = btn.dataset.category;

        // Update active tab
        tabs.forEach(t => t.classList.remove('is-active'));
        btn.classList.add('is-active');

        // Filter cards
        cards.forEach(card => {
          const cardEl = card as HTMLElement;
          if (category === 'all' || cardEl.dataset.category === category) {
            cardEl.style.display = '';
          } else {
            cardEl.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
