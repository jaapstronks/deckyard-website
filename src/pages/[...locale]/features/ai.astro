---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('featuresAi.meta.title')}
  description={t('featuresAi.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/features')}>{t('featuresAi.hero.backToFeatures')}</a></p>
      <h1>{t('featuresAi.hero.title')}</h1>
      <p class="lead">{t('featuresAi.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('featuresAi.fullDeck.title')}</h2>
      <p class="section-lead">{t('featuresAi.fullDeck.lead')}</p>

      <div class="two-col">
        <div>
          <h3>{t('featuresAi.fullDeck.howItWorks')}</h3>
          <ol class="numbered-list">
            <li>{t('featuresAi.fullDeck.step1')}</li>
            <li>{t('featuresAi.fullDeck.step2')}</li>
            <li>{t('featuresAi.fullDeck.step3')}</li>
            <li>{t('featuresAi.fullDeck.step4')}</li>
          </ol>

          <h3>{t('featuresAi.fullDeck.tipsTitle')}</h3>
          <ul class="bullets">
            <li>{t('featuresAi.fullDeck.tip1')}</li>
            <li>{t('featuresAi.fullDeck.tip2')}</li>
            <li>{t('featuresAi.fullDeck.tip3')}</li>
          </ul>
        </div>
        <div class="callout">
          <h3>{t('featuresAi.fullDeck.examplePrompts')}</h3>
          <p><em>{t('featuresAi.fullDeck.example1')}</em></p>
          <p style="margin-top: 12px;"><em>{t('featuresAi.fullDeck.example2')}</em></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('featuresAi.docConversion.title')}</h2>
      <p class="section-lead">{t('featuresAi.docConversion.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <h3>{t('featuresAi.docConversion.pdf.title')}</h3>
          <p>{t('featuresAi.docConversion.pdf.description')}</p>
        </article>
        <article class="card">
          <h3>{t('featuresAi.docConversion.word.title')}</h3>
          <p>{t('featuresAi.docConversion.word.description')}</p>
        </article>
        <article class="card">
          <h3>{t('featuresAi.docConversion.markdown.title')}</h3>
          <p>{t('featuresAi.docConversion.markdown.description')}</p>
        </article>
        <article class="card">
          <h3>{t('featuresAi.docConversion.text.title')}</h3>
          <p>{t('featuresAi.docConversion.text.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('featuresAi.byoKeys.title')}</h2>
      <p class="section-lead">{t('featuresAi.byoKeys.lead')}</p>

      <div class="two-col">
        <div>
          <h3>{t('featuresAi.byoKeys.providers')}</h3>
          <div class="provider-list">
            <div class="provider-item">
              <strong>{t('featuresAi.byoKeys.openai')}</strong>
              <span>{t('featuresAi.byoKeys.openaiModels')}</span>
            </div>
            <div class="provider-item">
              <strong>{t('featuresAi.byoKeys.anthropic')}</strong>
              <span>{t('featuresAi.byoKeys.anthropicModels')}</span>
            </div>
            <div class="provider-item">
              <strong>{t('featuresAi.byoKeys.mistral')}</strong>
              <span>{t('featuresAi.byoKeys.mistralModels')}</span>
            </div>
            <div class="provider-item">
              <strong>{t('featuresAi.byoKeys.deepseek')}</strong>
              <span>{t('featuresAi.byoKeys.deepseekModels')}</span>
            </div>
            <div class="provider-item">
              <strong>{t('featuresAi.byoKeys.openaiCompat')}</strong>
              <span>{t('featuresAi.byoKeys.openaiCompatModels')}</span>
            </div>
          </div>

          <h3 style="margin-top: 24px;">{t('featuresAi.byoKeys.setupTitle')}</h3>
          <ol class="numbered-list">
            <li>{t('featuresAi.byoKeys.setup1')}</li>
            <li>{t('featuresAi.byoKeys.setup2')}</li>
            <li>{t('featuresAi.byoKeys.setup3')}</li>
          </ol>
        </div>
        <div class="callout">
          <h3>{t('featuresAi.byoKeys.costs.title')}</h3>
          <p>{t('featuresAi.byoKeys.costs.lead')}</p>
          <ul class="bullets" style="margin-top: 12px;">
            <li><strong>{t('featuresAi.byoKeys.costs.gpt4o')}</strong></li>
            <li><strong>{t('featuresAi.byoKeys.costs.claude')}</strong></li>
            <li><strong>{t('featuresAi.byoKeys.costs.mistral')}</strong></li>
            <li><strong>{t('featuresAi.byoKeys.costs.deepseek')}</strong></li>
            <li><strong>{t('featuresAi.byoKeys.costs.local')}</strong></li>
          </ul>
          <p style="margin-top: 12px; font-size: 13px; color: var(--gray-500);">{t('featuresAi.byoKeys.costs.note')}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('featuresAi.whyByo.title')}</h2>
      <p class="section-lead">{t('featuresAi.whyByo.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <h3>{t('featuresAi.whyByo.noLimits.title')}</h3>
          <p>{t('featuresAi.whyByo.noLimits.description')}</p>
        </article>
        <article class="card">
          <h3>{t('featuresAi.whyByo.noMarkup.title')}</h3>
          <p>{t('featuresAi.whyByo.noMarkup.description')}</p>
        </article>
        <article class="card">
          <h3>{t('featuresAi.whyByo.chooseProvider.title')}</h3>
          <p>{t('featuresAi.whyByo.chooseProvider.description')}</p>
        </article>
        <article class="card">
          <h3>{t('featuresAi.whyByo.disableAi.title')}</h3>
          <p>{t('featuresAi.whyByo.disableAi.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('featuresAi.privacy.title')}</h2>
      <p class="section-lead">{t('featuresAi.privacy.lead')}</p>

      <div class="two-col">
        <div>
          <h3>{t('featuresAi.privacy.whatWeSend')}</h3>
          <ul class="bullets">
            <li>{t('featuresAi.privacy.send1')}</li>
            <li>{t('featuresAi.privacy.send2')}</li>
            <li>{t('featuresAi.privacy.send3')}</li>
          </ul>

          <h3 style="margin-top: 24px;">{t('featuresAi.privacy.whatWeDontStore')}</h3>
          <ul class="bullets">
            <li>{t('featuresAi.privacy.dontStore1')}</li>
            <li>{t('featuresAi.privacy.dontStore2')}</li>
            <li>{t('featuresAi.privacy.dontStore3')}</li>
          </ul>
        </div>
        <div>
          <h3>{t('featuresAi.privacy.selfHosting')}</h3>
          <p>{t('featuresAi.privacy.selfHostingDesc')}</p>
          <a class="btn btn-secondary" href={getLocalePath('/self-hosting')} style="margin-top: 16px;">{t('featuresAi.privacy.selfHostingGuide')}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('featuresAi.cta.title')}</h2>
      <p class="section-lead">{t('featuresAi.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('featuresAi.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href="/docs/">
          {t('featuresAi.cta.readDocs')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
