---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('features.meta.title')}
  description={t('features.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('features.hero.backToHome')}</a></p>
      <h1>{t('features.hero.title')}</h1>
      <p class="lead">{t('features.hero.lead')}</p>

      <div class="cta-row section-cta-spacer">
        <a class="btn btn-secondary" href={getLocalePath('/features/slide-types')}>{t('features.quickLinks.slideTypes')}</a>
        <a class="btn btn-secondary" href={getLocalePath('/features/ai')}>{t('features.quickLinks.aiGeneration')}</a>
        <a class="btn btn-secondary" href={getLocalePath('/features/interactions')}>{t('features.quickLinks.liveInteractions')}</a>
      </div>
    </div>
  </section>

  <!-- SLIDE TYPES -->
  <section class="section">
    <div class="container">
      <h2>{t('features.slideTypes.title')}</h2>
      <p class="section-lead">{t('features.slideTypes.lead')}</p>

      <div class="grid cards">
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/chart.png" alt="Chart slide type showing data visualization" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
            <h3>{t('features.slideTypes.data.title')}</h3>
            <p>{t('features.slideTypes.data.description')}</p>
          </div>
        </article>
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/poll.png" alt="Interactive poll slide type" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
            <h3>{t('features.slideTypes.interactive.title')}</h3>
            <p>{t('features.slideTypes.interactive.description')}</p>
          </div>
        </article>
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/iconCards.png" alt="Icon cards layout slide type" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
            <h3>{t('features.slideTypes.cards.title')}</h3>
            <p>{t('features.slideTypes.cards.description')}</p>
          </div>
        </article>
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/gallery.png" alt="Media gallery slide type" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
            <h3>{t('features.slideTypes.media.title')}</h3>
            <p>{t('features.slideTypes.media.description')}</p>
          </div>
        </article>
      </div>

      <div class="cta-center section-cta-spacer">
        <a class="btn btn-secondary" href={getLocalePath('/features/slide-types')}>{t('features.slideTypes.viewAll')}</a>
      </div>
    </div>
  </section>

  <!-- AI GENERATION -->
  <section class="section section-alt">
    <div class="container">
      <h2>{t('features.ai.title')}</h2>
      <p class="section-lead">{t('features.ai.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('features.ai.fullDeck.title')}</h3>
          <p>{t('features.ai.fullDeck.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('features.ai.docConversion.title')}</h3>
          <p>{t('features.ai.docConversion.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('features.ai.byoKeys.title')}</h3>
          <p>{t('features.ai.byoKeys.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-database"></use></svg></div>
          <h3>{t('features.ai.typicalCosts.title')}</h3>
          <p>{t('features.ai.typicalCosts.description')}</p>
        </article>
      </div>

      <div class="cta-center section-cta-spacer">
        <a class="btn btn-secondary" href={getLocalePath('/features/ai')}>{t('features.ai.learnMore')}</a>
      </div>
    </div>
  </section>

  <!-- INTERACTIONS -->
  <section class="section">
    <div class="container">
      <h2>{t('features.interactions.title')}</h2>
      <p class="section-lead">{t('features.interactions.lead')}</p>

      <div class="grid cards">
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/poll.png" alt="Live poll slide with voting options" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
            <h3>{t('features.interactions.livePolls.title')}</h3>
            <p>{t('features.interactions.livePolls.description')}</p>
          </div>
        </article>
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/feedback.png" alt="Q&A feedback slide" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
            <h3>{t('features.interactions.qna.title')}</h3>
            <p>{t('features.interactions.qna.description')}</p>
          </div>
        </article>
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/likert.png" alt="Likert scale rating slide" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
            <h3>{t('features.interactions.likert.title')}</h3>
            <p>{t('features.interactions.likert.description')}</p>
          </div>
        </article>
        <article class="card card-visual">
          <div class="card-thumb">
            <img src="/images/slide-types/likertSlider.png" alt="Feedback collection slide" loading="lazy" />
          </div>
          <div class="card-body">
            <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
            <h3>{t('features.interactions.feedback.title')}</h3>
            <p>{t('features.interactions.feedback.description')}</p>
          </div>
        </article>
      </div>

      <div class="cta-center section-cta-spacer">
        <a class="btn btn-secondary" href={getLocalePath('/features/interactions')}>{t('features.interactions.learnMore')}</a>
      </div>
    </div>
  </section>

  <!-- IMPORT -->
  <section class="section section-alt">
    <div class="container">
      <h2>{t('features.import.title')}</h2>
      <p class="section-lead">{t('features.import.lead')}</p>

      <div class="grid cards">
        <article class="card card-highlight">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('features.import.markdown.title')}</h3>
          <p>{t('features.import.markdown.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('features.import.pptx.title')}</h3>
          <p>{t('features.import.pptx.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-link"></use></svg></div>
          <h3>{t('features.import.notion.title')}</h3>
          <p>{t('features.import.notion.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('features.import.text.title')}</h3>
          <p>{t('features.import.text.description')}</p>
        </article>
      </div>

      <div class="cta-center section-cta-spacer">
        <a class="btn btn-secondary" href="/docs/creating/">{t('features.import.learnMore')}</a>
      </div>
    </div>
  </section>

  <!-- EXPORT -->
  <section class="section">
    <div class="container">
      <h2>{t('features.export.title')}</h2>
      <p class="section-lead">{t('features.export.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('features.export.pdf.title')}</h3>
          <p>{t('features.export.pdf.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('features.export.pptx.title')}</h3>
          <p>{t('features.export.pptx.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('features.export.html.title')}</h3>
          <p>{t('features.export.html.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('features.export.json.title')}</h3>
          <p>{t('features.export.json.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- COLLABORATION -->
  <section class="section section-alt">
    <div class="container">
      <h2>{t('features.collaboration.title')}</h2>
      <p class="section-lead">{t('features.collaboration.lead')}</p>

      <div class="grid cards-3">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-database"></use></svg></div>
          <h3>{t('features.collaboration.workspaces.title')}</h3>
          <p>{t('features.collaboration.workspaces.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('features.collaboration.permissions.title')}</h3>
          <p>{t('features.collaboration.permissions.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('features.collaboration.assets.title')}</h3>
          <p>{t('features.collaboration.assets.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-sparkle"></use></svg></div>
          <h3>{t('features.collaboration.themes.title')}</h3>
          <p>{t('features.collaboration.themes.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('features.collaboration.audit.title')}</h3>
          <p>{t('features.collaboration.audit.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-lock"></use></svg></div>
          <h3>{t('features.collaboration.sso.title')}</h3>
          <p>{t('features.collaboration.sso.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-cta">
    <div class="container">
      <h2>{t('features.cta.title')}</h2>
      <p class="section-lead">{t('features.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('features.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>
          {t('features.cta.selfHosting')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
