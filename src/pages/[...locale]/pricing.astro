---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('pricing.meta.title')}
  description={t('pricing.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('pricing.hero.title')}</h1>
      <p class="lead">{t('pricing.hero.lead')}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pricing-grid">
        <article class="pricing-card pricing-card-highlight">
          <div class="pricing-header">
            <h2 class="pricing-name">{t('pricing.plans.selfHosted.name')}</h2>
            <p class="pricing-price">{t('pricing.plans.selfHosted.price')}</p>
            <p class="pricing-period">{t('pricing.plans.selfHosted.period')}</p>
          </div>
          <ul class="pricing-features">
            <li>{t('pricing.plans.selfHosted.features.unlimitedPresentations')}</li>
            <li>{t('pricing.plans.selfHosted.features.unlimitedAudience')}</li>
            <li>{t('pricing.plans.selfHosted.features.allSlideTypes')}</li>
            <li>{t('pricing.plans.selfHosted.features.allInteractive')}</li>
            <li>{t('pricing.plans.selfHosted.features.aiGeneration')}</li>
            <li>{t('pricing.plans.selfHosted.features.fullSource')}</li>
            <li>{t('pricing.plans.selfHosted.features.mitLicense')}</li>
            <li>{t('pricing.plans.selfHosted.features.yourData')}</li>
          </ul>
          <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>{t('pricing.plans.selfHosted.cta')}</a>
        </article>

        <article class="pricing-card">
          <div class="pricing-header">
            <h2 class="pricing-name">{t('pricing.plans.pro.name')}</h2>
            <p class="pricing-price">{t('pricing.plans.pro.price')}</p>
            <p class="pricing-period">{t('pricing.plans.pro.period')}</p>
          </div>
          <ul class="pricing-features">
            <li>{t('pricing.plans.pro.features.everything')}</li>
            <li>{t('pricing.plans.pro.features.managedHosting')}</li>
            <li>{t('pricing.plans.pro.features.autoUpdates')}</li>
            <li>{t('pricing.plans.pro.features.storage')}</li>
            <li>{t('pricing.plans.pro.features.emailSupport')}</li>
            <li>{t('pricing.plans.pro.features.dailyBackups')}</li>
            <li>{t('pricing.plans.pro.features.customDomain')}</li>
            <li>{t('pricing.plans.pro.features.byoAi')}</li>
          </ul>
          <a class="btn btn-primary btn-lg" href="mailto:hello@deckyard.eu?subject=Pro%20plan%20inquiry">{t('pricing.plans.pro.cta')}</a>
        </article>

        <article class="pricing-card">
          <div class="pricing-header">
            <h2 class="pricing-name">{t('pricing.plans.team.name')}</h2>
            <p class="pricing-price">{t('pricing.plans.team.price')}</p>
            <p class="pricing-period">{t('pricing.plans.team.period')}</p>
          </div>
          <ul class="pricing-features">
            <li>{t('pricing.plans.team.features.everything')}</li>
            <li>{t('pricing.plans.team.features.teamMembers')}</li>
            <li>{t('pricing.plans.team.features.sharedWorkspaces')}</li>
            <li>{t('pricing.plans.team.features.roleBasedPermissions')}</li>
            <li>{t('pricing.plans.team.features.storage')}</li>
            <li>{t('pricing.plans.team.features.prioritySupport')}</li>
            <li>{t('pricing.plans.team.features.auditLog')}</li>
            <li>{t('pricing.plans.team.features.sso')}</li>
          </ul>
          <a class="btn btn-primary btn-lg" href="mailto:hello@deckyard.eu?subject=Team%20plan%20inquiry">{t('pricing.plans.team.cta')}</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('pricing.faq.title')}</h2>

      <div class="faq">
        <details class="faq-item">
          <summary class="faq-question">{t('pricing.faq.selfHostedIncludes.question')}</summary>
          <p class="faq-answer">{t('pricing.faq.selfHostedIncludes.answer')}</p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">{t('pricing.faq.aiCosts.question')}</summary>
          <p class="faq-answer">{t('pricing.faq.aiCosts.answer')}</p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">{t('pricing.faq.enterprise.question')}</summary>
          <p class="faq-answer">{t('pricing.faq.enterprise.answer')}</p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">{t('pricing.faq.switchPlans.question')}</summary>
          <p class="faq-answer">{t('pricing.faq.switchPlans.answer')}</p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">{t('pricing.faq.paymentMethods.question')}</summary>
          <p class="faq-answer">{t('pricing.faq.paymentMethods.answer')}</p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">{t('pricing.faq.discounts.question')}</summary>
          <p class="faq-answer">{t('pricing.faq.discounts.answer')}</p>
        </details>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{t('pricing.compare.title')}</h2>
      <p class="section-lead">{t('pricing.compare.lead')}</p>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>Deckyard</th>
              <th>Mentimeter</th>
              <th>Slides.com</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{t('pricing.compare.freeTier')}</td>
              <td class="yes">{t('pricing.compare.deckyard.freeTier')}</td>
              <td class="partial">{t('pricing.compare.mentimeter.freeTier')}</td>
              <td class="partial">{t('pricing.compare.slidescom.freeTier')}</td>
            </tr>
            <tr>
              <td>{t('pricing.compare.proPricing')}</td>
              <td>{t('pricing.compare.deckyard.proPricing')}</td>
              <td>{t('pricing.compare.mentimeter.proPricing')}</td>
              <td>{t('pricing.compare.slidescom.proPricing')}</td>
            </tr>
            <tr>
              <td>{t('pricing.compare.teamPricing')}</td>
              <td>{t('pricing.compare.deckyard.teamPricing')}</td>
              <td>{t('pricing.compare.mentimeter.teamPricing')}</td>
              <td>{t('pricing.compare.slidescom.teamPricing')}</td>
            </tr>
            <tr>
              <td>{t('pricing.compare.teamCost')}</td>
              <td class="yes">{t('pricing.compare.deckyard.teamCost')}</td>
              <td class="no">{t('pricing.compare.mentimeter.teamCost')}</td>
              <td class="no">{t('pricing.compare.slidescom.teamCost')}</td>
            </tr>
            <tr>
              <td>{t('pricing.compare.aiFeatures')}</td>
              <td class="yes">{t('pricing.compare.deckyard.aiFeatures')}</td>
              <td class="partial">{t('pricing.compare.mentimeter.aiFeatures')}</td>
              <td class="no">{t('pricing.compare.slidescom.aiFeatures')}</td>
            </tr>
            <tr>
              <td>{t('pricing.compare.selfHostOption')}</td>
              <td class="yes">{t('pricing.compare.deckyard.selfHostOption')}</td>
              <td class="no">{t('pricing.compare.mentimeter.selfHostOption')}</td>
              <td class="no">{t('pricing.compare.slidescom.selfHostOption')}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('pricing.cta.title')}</h2>
      <p class="section-lead">{t('pricing.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://sandbox.deckyard.eu">
          {t('pricing.cta.trySandbox')}
        </a>
        <a class="btn btn-secondary btn-lg" href={getLocalePath('/self-hosting')}>
          {t('pricing.cta.selfHostingGuide')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
