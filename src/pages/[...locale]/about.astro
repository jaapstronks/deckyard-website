---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(l => l !== defaultLocale).map(locale => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale || defaultLocale) as Locale;
const t = useTranslations(locale);

function getLocalePath(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<BaseLayout
  title={t('about.meta.title')}
  description={t('about.meta.description')}
  locale={locale}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow"><a href={getLocalePath('/')}>{t('nav.backToHome')}</a></p>
      <h1>{t('about.hero.title')}</h1>
      <p class="lead">{t('about.hero.lead')}</p>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('about.mission.title')}</h2>
      <p class="section-lead">{t('about.mission.lead')}</p>
      <p>{t('about.mission.description')}</p>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('about.story.title')}</h2>
      <p>{t('about.story.paragraph1')}</p>
      <p>{t('about.story.paragraph2')}</p>
      <p>{t('about.story.paragraph3')}</p>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('about.philosophy.title')}</h2>
      <p class="section-lead">{t('about.philosophy.lead')}</p>
      <p>{t('about.philosophy.paragraph1')}</p>
      <p>{t('about.philosophy.paragraph2')}</p>
      <p><strong>{t('about.philosophy.paragraph3')}</strong></p>

      <div class="callout" style="margin-top: 2rem;">
        <h3>{t('about.philosophy.semantic.title')}</h3>
        <p>{t('about.philosophy.semantic.description')}</p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{t('about.values.title')}</h2>
      <p class="section-lead">{t('about.values.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('about.values.transparency.title')}</h3>
          <p>{t('about.values.transparency.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-shield-check"></use></svg></div>
          <h3>{t('about.values.privacy.title')}</h3>
          <p>{t('about.values.privacy.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-globe"></use></svg></div>
          <h3>{t('about.values.sovereignty.title')}</h3>
          <p>{t('about.values.sovereignty.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('about.values.sustainable.title')}</h3>
          <p>{t('about.values.sustainable.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt content-section">
    <div class="container">
      <h2>{t('about.legal.title')}</h2>
      <p class="section-lead">{t('about.legal.lead')}</p>

      <div class="data-table-wrap">
        <table class="data-table">
          <tbody>
            <tr>
              <td><strong>{t('about.legal.entityName')}</strong></td>
              <td>Deckyard B.V.</td>
            </tr>
            <tr>
              <td><strong>{t('about.legal.location')}</strong></td>
              <td>Rotterdam, Netherlands</td>
            </tr>
            <tr>
              <td><strong>{t('about.legal.chamberOfCommerce')}</strong></td>
              <td>KVK 12345678</td>
            </tr>
            <tr>
              <td><strong>{t('about.legal.vatNumber')}</strong></td>
              <td>NL123456789B01</td>
            </tr>
            <tr>
              <td><strong>{t('about.legal.email')}</strong></td>
              <td><a href="mailto:hello@deckyard.eu">hello@deckyard.eu</a></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section content-section">
    <div class="container">
      <h2>{t('about.community.title')}</h2>
      <p class="section-lead">{t('about.community.lead')}</p>

      <div class="grid cards">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-code"></use></svg></div>
          <h3>{t('about.community.contribute.title')}</h3>
          <p>{t('about.community.contribute.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-users"></use></svg></div>
          <h3>{t('about.community.discuss.title')}</h3>
          <p>{t('about.community.discuss.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-file-text"></use></svg></div>
          <h3>{t('about.community.translate.title')}</h3>
          <p>{t('about.community.translate.description')}</p>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><svg class="icon"><use href="#icon-chart-bar"></use></svg></div>
          <h3>{t('about.community.feedback.title')}</h3>
          <p>{t('about.community.feedback.description')}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-cta">
    <div class="container">
      <h2>{t('about.cta.title')}</h2>
      <p class="section-lead">{t('about.cta.lead')}</p>
      <div class="cta-row cta-center">
        <a class="btn btn-primary btn-lg" href="https://github.com/deckyard/deckyard" target="_blank" rel="noreferrer">
          {t('about.cta.viewOnGithub')}
        </a>
        <a class="btn btn-secondary btn-lg" href="mailto:hello@deckyard.eu">
          {t('about.cta.contactUs')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
